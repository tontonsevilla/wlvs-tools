<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@WLVSTools.Web.Core.Models.AppConstant.PortalName | @ViewBag.PageTitle</title>
    <bundle name="wwwroot/bundles/css/adminlte.min.css" />
    <bundle name="wwwroot/bundles/css/site.min.css" />
</head>
<body class="hold-transition sidebar-mini">
    <div class="wrapper">

        <nav class="main-header navbar navbar-expand navbar-white navbar-light">

            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="index3.html" class="nav-link">Home</a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="#" class="nav-link">Contact</a>
                </li>
            </ul>

            <ul class="navbar-nav ml-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link" data-toggle="dropdown" href="#">
                        <i class="fas fa-user"></i> @User.Identity.Name
                    </a>
                    <div class="dropdown-menu dropdown-menu-lg dropdown-menu-right">
                        <a href="~/Account/Logout" class="dropdown-item">
                            Logout&nbsp;<i class="fas fa-sign-out-alt"></i>
                        </a>
                        @* <div class="dropdown-divider"></div> *@
                    </div>
                </li>
            </ul>
        </nav>


        <aside class="main-sidebar sidebar-dark-primary elevation-4">

            <a href="index3.html" class="brand-link">
                <img src="~/lib/admin-lte/img/AdminLTELogo.png" alt="AdminLTE Logo" class="brand-image img-circle elevation-3" style="opacity: .8">
                <span class="brand-text font-weight-light">WLVS Tools</span>
            </a>

            <div class="sidebar">

                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
                        <!--PERSONAL TOOLBOX-->
                        <li class="nav-item">
                            <a id="menuPersonalToolbox" href="#" class="nav-link">
                                <i class="nav-icon fas fa-toolbox"></i>
                                <p>
                                    Personal Toolbox
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" data-parent-menu-id="menuPersonalToolbox">
                                <li class="nav-item">
                                    <a id="menuAccountList" href="~/PersonalToolbox/AccountList" class="nav-link">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Account List</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a id="menuContactList" href="~/PersonalToolbox/ContactList" class="nav-link">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Contact List</p>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <!--WORK TOOLBOX-->
                        <li class="nav-item">
                            <a id="menuWorkToolbox" href="#" class="nav-link">
                                <i class="nav-icon fas fa-toolbox"></i>
                                <p>
                                    Work Toolbox
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" data-parent-menu-id="menuWorkToolbox">
                                <li class="nav-item">
                                    <a id="menuWork1" href="#" class="nav-link">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Work 1</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a id="menuWork2" href="#" class="nav-link">
                                        <i class="far fa-circle nav-icon"></i>
                                        <p>Work 2</p>
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </nav>

            </div>

        </aside>

        <div class="content-wrapper">

            <div class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                            <h1 class="m-0">@ViewBag.PageTitle</h1>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="#">Home</a></li>
                                <li class="breadcrumb-item active">Starter Page</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>


            <div class="content">
                <div class="container-fluid">
                    @RenderBody()

                </div>
            </div>

        </div>


        <aside class="control-sidebar control-sidebar-dark">

            <div class="p-3">
                <h5>Title</h5>
                <p>Sidebar content</p>
            </div>
        </aside>


        <footer class="main-footer">

            <div class="float-right d-none d-sm-inline">
                Powered by: <a href="https://adminlte.io">AdminLTE.io</a>
            </div>

            <strong>Copyright &copy; 2023 InfoWLVS.</strong> All rights reserved.
        </footer>
    </div>
    <bundle name="wwwroot/bundles/js/jquery.min.js" />
    <bundle name="wwwroot/bundles/js/bootstrap.min.js" />
    <bundle name="wwwroot/bundles/js/adminlte.min.js" />
    <bundle name="wwwroot/bundles/js/site.min.js" />

</body>
</html>